{
  "name": "persona-review",
  "version": "0.5.0",
  "description": "AI persona feedback tool for web pages — visit a page as a simulated persona and get reactions, friction points, and suggestions.",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/osvik/persona-review.git"
  },
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "persona-review": "dist/cli.js"
  },
  "files": [
    "dist",
    "personas",
    "submit-data.yaml",
    "npm-shrinkwrap.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prepublishOnly": "npm run build",
    "review": "node dist/cli.js",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.40.1",
    "playwright": "1.59.1",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
